mixin publicacion(item, comentarios) 
  div.publicacion
    div#publicacionparteuno
      if item.imagenes && item.imagenes.length > 0 
        div#contadorImagenes(style="text-align: center; font-weight: bold; margin-bottom: 10px;") 0 / 0
        
        div#imagenes
          div 
            img#izquierda(src="/left.png", alt="izquierda", height="30px")
          div 
            img#imagenPrincipal(src="", alt="publicacion")
            div#valorar promedio: 0
          div
            img#derecha(src="/right.png", alt="derecha", height="30px")
      else
        p imagen no encontrada
          
      h1= item.titulo
      p= item.descripcion

      if item.etiquetas && item.etiquetas.length > 0
        div 
          ul
            each etiqueta in item.etiquetas
              li= etiqueta.nombre
      else
        p.sin-etiquetas Sin etiquetas

    div#publicacioncomentarios
      div.lista-comentarios
        h1 Comentarios
        div#cajaComentarios(style="max-height: 300px; overflow-y: auto; margin-bottom: 15px;")

      form(action='/crearComentario' method='POST')
        input(type='hidden' name='post_id' value=item.id)
        input(type='hidden' id='inputImagenId' name='imagen_id' value="")
        textarea(name='contenido' placeholder='Escribe un comentario...' required)
        input(type='submit' value='Comentar')

    script.
      const listaImagenes = !{JSON.stringify(item.imagenes || [])};
      const todosLosComentarios = !{JSON.stringify(comentarios || [])};
      let indiceImagenActual = 0;

      const elementoImagenPrincipal = document.querySelector('#imagenPrincipal');
      const elementoTextoValoracion = document.querySelector('#valorar');
      const elementoInputImagenId = document.querySelector('#inputImagenId');
      const elementoCajaComentarios = document.querySelector('#cajaComentarios');
      const elementoContadorImagenes = document.querySelector('#contadorImagenes');
      
      // Botones del carrusel
      const botonAnterior = document.querySelector('#izquierda');
      const botonSiguiente = document.querySelector('#derecha');

      // actualizar comentarios
      function actualizarComentariosPorImagen(imagenId) {
        elementoCajaComentarios.innerHTML = "";

        const comentariosFiltrados = todosLosComentarios.filter(function(comentario) {
          return comentario.imagen_id === imagenId;
        });

        if (comentariosFiltrados.length > 0) {
          comentariosFiltrados.forEach(function(comentario) {
            const itemComentario = document.createElement('div');
            itemComentario.className = 'comentario-item';
            itemComentario.style.borderBottom = '1px solid #eee';
            itemComentario.style.padding = '8px 0';

            const etiquetaUsuario = document.createElement('strong');
            etiquetaUsuario.textContent = comentario.usuario ? comentario.usuario.username : "Usuario";

            const textoContenido = document.createElement('p');
            textoContenido.style.margin = '4px 0';
            textoContenido.textContent = comentario.contenido;

            itemComentario.appendChild(etiquetaUsuario);
            itemComentario.appendChild(textoContenido);
            elementoCajaComentarios.appendChild(itemComentario);
          });
        } else {
          const sinComentarios = document.createElement('p');
          sinComentarios.className = 'sin-comentarios';
          sinComentarios.textContent = 'No hay comentarios aún. Sé el primero en comentar.';
          elementoCajaComentarios.appendChild(sinComentarios);
        }
      }

      function renderizarImagenActual() {
        if (listaImagenes.length === 0) return;

        const imagenActual = listaImagenes[indiceImagenActual];

        elementoImagenPrincipal.setAttribute("src", imagenActual.url);
        elementoTextoValoracion.textContent = "promedio: " + (imagenActual.promedio || 0);
        elementoInputImagenId.value = imagenActual.id;
        elementoContadorImagenes.textContent = (indiceImagenActual + 1) + " / " + listaImagenes.length;

        actualizarComentariosPorImagen(imagenActual.id);
      }

      function cambiarIndiceImagen(direccion) {
        indiceImagenActual = indiceImagenActual + direccion;

        if (indiceImagenActual < 0) {
          indiceImagenActual = listaImagenes.length - 1;
        }
        if (indiceImagenActual >= listaImagenes.length) {
          indiceImagenActual = 0;
        }

        renderizarImagenActual();
      }

      if (listaImagenes.length > 0) {
        botonAnterior.addEventListener('click', function() {
          cambiarIndiceImagen(-1);
        });

        botonSiguiente.addEventListener('click', function() {
          cambiarIndiceImagen(1);
        });
        renderizarImagenActual();
      }