mixin publicacion(item) 
  div.publicacion(data-post-id=item.id)
    style.
      .publicacion, .publicacion * {
        box-sizing: border-box;
      }
      .publicacion h1, .publicacion p, .publicacion li, .autor-publicacion {
        word-break: break-word;
        overflow-wrap: break-word;
        max-width: 100%;
      }
      #publicacionparteuno {
        overflow-y: auto;
      }
      .imagenes-contenedor {
        display: flex;
        flex-direction: row;
        align-items: center;
        justify-content: space-between;
        width: 100%;
        height: 320px;
        margin-bottom: 20px;
        background-color: #fafafa;
        border-radius: 12px;
        padding: 10px;
        overflow: hidden;
        flex-shrink: 0;
      }
      .imagenPrincipal {
        max-width: 85%;
        max-height: 100%;
        width: auto;
        height: auto;
        object-fit: contain;
        display: block;
        margin: 0 auto;
        flex-shrink: 0;
      }
    div#publicacionparteuno
      if item.creador
        a(href="/perfil/" + item.creador.id style="text-decoration: none; color: inherit;")
          p.autor-publicacion Creador de la publicación: #{item.creador.username}
      else
        p.autor-publicacion Creador: Anónimo

      if item.imagenes && item.imagenes.length > 0 
        div.contadorImagenes 1 / #{item.imagenes.length}
        div.imagenes-contenedor
          img.btn-izquierda(src="/left.png" height="30px" style="cursor:pointer")
          img.imagenPrincipal(src="")
          img.btn-derecha(src="/right.png" height="30px" style="cursor:pointer")
        div.caracteristicas
          p.promedio Promedio: 0
          p.copyright
          
          div.bloqueValorar
            form(action="/crearValoracion" method="POST")
              input.inputImagenId2(type='hidden' name='imagen_id' value="")
              input.valordevalorar(type="range" min="1" max="10" value="5" name="valor")
              input(type='hidden' name='post_id' value=item.id)
              p.valorTexto Valor: 5
              input(type="submit" value="Valorar")
      else
        p Imagen no encontrada
          
      h1= item.titulo
      p= item.descripcion

      if item.etiquetas && item.etiquetas.length > 0
        ul
          each etq in item.etiquetas
            li= etq.nombre

    div#publicacioncomentarios
      div
        h1 Comentarios
        div.cajaComentarios

      form(action='/crearComentario' method='POST')
        input(type='hidden' name='post_id' value=item.id)
        input.inputImagenId(type='hidden' name='imagen_id' value="")
        textarea(name='contenido' required placeholder="Escribe un comentario...")
        input(type='submit' value='Comentar')

    script.
      (function() {
        const imagenes = !{JSON.stringify(item.imagenes || [])};
        let index = 0;

        const contenedor = document.querySelector('[data-post-id="' + !{item.id} + '"]');
        if (!contenedor) return;

        // variables
        const btnDerecha = contenedor.querySelector(".btn-derecha");
        const btnIzquierda = contenedor.querySelector(".btn-izquierda");
        const rangevoto = contenedor.querySelector(".valordevalorar");
        const txtvoto = contenedor.querySelector(".valorTexto");
        const elImagen = contenedor.querySelector(".imagenPrincipal");
        const elPromedio = contenedor.querySelector(".promedio");
        const elContador = contenedor.querySelector(".contadorImagenes");
        const cajaCmts = contenedor.querySelector(".cajaComentarios");
        const inputsId = contenedor.querySelectorAll(".inputImagenId, .inputImagenId2");

        if (rangevoto && txtvoto) {
          rangevoto.addEventListener("input", function() {
            txtvoto.textContent = "Valor: " + rangevoto.value;
          });
        }

        function cargarDatos() {
          if (!imagenes.length || !elImagen) return;
          const img = imagenes[index];

          elImagen.src = img.url || img.ruta; 
          
          if (elContador) {
            elContador.textContent = (index + 1) + " / " + imagenes.length;
          }
          
          inputsId.forEach(function(input) {
            input.value = img.id || 0;
          });
          
          const votos = img.valoraciones || [];
          let suma = 0;
          for (let i = 0; i < votos.length; i++) {
            suma += Number(votos[i].puntaje);
          }

          let promedio = 0;
          if (votos.length > 0) {
            promedio = (suma / votos.length).toFixed(1);
          }

          if (elPromedio) {
            elPromedio.textContent = "Promedio: " + promedio;
          }
          
          if (rangevoto && txtvoto) {
            rangevoto.value = 5;
            txtvoto.textContent = "Valor: 5";
          }

          const comentarios = img.comentarios || [];
          let htmlComentarios = "";

          if (comentarios.length > 0) {
            comentarios.forEach(function(c) {
              const nombreUsuario = c.usuario ? c.usuario.username : "Usuario Anónimo";
              htmlComentarios += '<div class="comentario">';
              htmlComentarios += '  <strong>' + nombreUsuario + ': </strong>';
              htmlComentarios += '  <p>' + c.contenido + '</p>';
              htmlComentarios += '</div>';
            });
          } else {
            htmlComentarios = "<p>No hay comentarios aún.</p>";
          }

          if (cajaCmts) {
            cajaCmts.innerHTML = htmlComentarios;
          }
        }

        //carrusel
        if (imagenes.length) {
          if (btnIzquierda) {
            btnIzquierda.addEventListener("click", function() {
              index = (index - 1 + imagenes.length) % imagenes.length;
              cargarDatos();
            });
          }
          if (btnDerecha) {
            btnDerecha.addEventListener("click", function() {
              index = (index + 1) % imagenes.length;
              cargarDatos();
            });
          }
          cargarDatos();
        }
      })();