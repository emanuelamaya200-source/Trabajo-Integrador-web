mixin publicacion(item) 
  div.publicacion
    div#publicacionparteuno
      if item.imagenes && item.imagenes.length > 0 
        div#contadorImagenes 0 / 0
        div#imagenes
          img#izquierda(src="/left.png" height="30px")
          img#imagenPrincipal(src="")
          img#derecha(src="/right.png" height="30px")
        div#caracteristicas
          p#promedio Promedio: 0
          p#copyright
          div#bloqueValorar
            form(action="/crearValoracion" method="POST")
              input#inputImagenId2(type='hidden' name='imagen_id' value="")
              input#valordevalorar(type="range" min="1" max="10" value="5" name="valor")
              input(type='hidden' name='post_id' value=item.id)
              p#valorTexto Valor: 5
              input(type="submit" value="Valorar")
      else
        p imagen no encontrada
          
      h1= item.titulo
      p= item.descripcion

      if item.etiquetas && item.etiquetas.length > 0
        ul
          each etq in item.etiquetas
            li= etq.nombre

    div#publicacioncomentarios
      div
        h1 Comentarios
        div#cajaComentarios

      form(action='/crearComentario' method='POST')
        input(type='hidden' name='post_id' value=item.id)
        input#inputImagenId(type='hidden' name='imagen_id' value="")
        textarea(name='contenido' required placeholder="Escribe un comentario...")
        input(type='submit' value='Comentar')

    script.
      const imagenes = !{JSON.stringify(item.imagenes || [])};
      let index = 0;

      const btnDerecha = document.querySelector("#derecha");
      const btnIzquierda = document.querySelector("#izquierda");
      const rangevoto = document.querySelector("#valordevalorar");
      const txtvoto = document.querySelector("#valorTexto");
      const elImagen = document.querySelector("#imagenPrincipal");
      const elPromedio = document.querySelector("#promedio");
      const elContador = document.querySelector("#contadorImagenes");
      const cajaCmts = document.querySelector("#cajaComentarios");
      // Selecciona los dos inputs ocultos de los ID de imagen a la vez
      const inputsId = document.querySelectorAll("#inputImagenId, #inputImagenId2");

      if (rangevoto) {
        rangevoto.addEventListener("input", () => txtvoto.textContent = `Valor: ${rangevoto.value}`);
      }

      function cargarDatos() {
        if (!imagenes.length) return;
        const img = imagenes[index];

        elImagen.src = img.url;
        elContador.textContent = `${index + 1} / ${imagenes.length}`;
        inputsId.forEach(input => input.value = img.id);
        
        
        const votos = img.valoraciones || [];
        let suma = 0;

        // Recorremos los votos y los sumamos uno a uno
        for (const v of votos) {
            suma += Number(v.puntaje);
        }

        // Calculamos el promedio dividiendo por la cantidad (si hay votos)
        let promedio = 0;
        if (votos.length > 0) {
            promedio = (suma / votos.length).toFixed(1);
        }

        elPromedio.textContent = `Promedio: ${promedio}`;
        
        if (rangevoto) {
          rangevoto.value = 5;
          txtvoto.textContent = "Valor: 5";
        }

        const comentarios = img.comentarios || [];
        cajaCmts.innerHTML = comentarios.length 
          ? comentarios.map(c => `<div><strong>${c.usuario ? c.usuario.username : "Usuario"}</strong><p>${c.contenido}</p></div>`).join("")
          : "<p>No hay comentarios aún.</p>";
      }

      if (imagenes.length) {
        btnIzquierda.addEventListener("click", () => {
          index = (index - 1 + imagenes.length) % imagenes.length;
          cargarDatos();
        });
        btnDerecha.addEventListener("click", () => {
          index = (index + 1) % imagenes.length;
          cargarDatos();
        });
        cargarDatos();
      }