extends layout 

block estilo 
    style.
            #iniciopagina {
                position: relative;
                height: 100vh;
                width: 100%;
                display: flex;
            }
            #iniciopagina::before {
                content: "";
                position: absolute;
                inset: 0;
                z-index: -1;
                background: url('/iniciofv.png') no-repeat center;
                background-size: cover;
            }
            form {
                display: flex; 
                flex-direction: column;
                position: absolute;
                gap: 10px; 
                width: 300px; 
                right: 10%; 
                top: 30%;
            }

block content 
    div#iniciopagina 
        form(action='/login' method='POST')
            h3 Iniciar Sesion

            label(for='email') Email
            input#email(type='email' name='email')

            label(for='contrasena') Contraseña
            input#contrasena(type='password' name='contrasena')

            input(type='submit' value='Iniciar')
